# QuantLab Lite — Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL connection
DATABASE_URL=postgresql://quantlab:quantlab@localhost:5432/quantlab

# Risk-free rate (annualized, e.g. 0.02 = 2%)
RISK_FREE_RATE=0.02

# Trading days per year
TRADING_DAYS_PER_YEAR=252

# Default interval for data downloads
DEFAULT_INTERVAL=1d
